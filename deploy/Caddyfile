{$DOMAIN} {
    encode gzip
    tls /certs/domain.cert.pem /certs/private.key.pem

    # Routes API traffic to Django using /api prefix.
    handle_path /api/* {
        reverse_proxy backend:8000
    }

    # Optional direct access to Django admin and browsable auth pages.
    @django path /admin* /api-auth*
    handle @django {
        reverse_proxy backend:8000
    }

    # Everything else goes to the React app.
    handle {
        reverse_proxy frontend:80
    }
}
